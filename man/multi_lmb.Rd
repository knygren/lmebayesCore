## Multi-response lmb (iris): formula interface, mlmb class

set.seed(42)
data("iris", package = "datasets")

form_multi <- cbind(Sepal.Length, Sepal.Width, Petal.Length, Petal.Width) ~ Species

ps_multi <- multi_prior_setup(
  form_multi,
  data = iris,
  family = gaussian()
